<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <worksheet-extension id="com.vizext.radarchart.standalone" extension-version="1.0.0">
    <default-locale>en_US</default-locale>
    <name resource-id="name"/>
    <description>Radar Chart Viz Extension — hosted on GitHub Pages.</description>
    <author name="Custom Viz" email="admin@example.com" organization="Custom Viz" website="https://example.com"/>
    <min-api-version>1.10</min-api-version>
    <source-location>
        <url>https://YOUR-USERNAME.github.io/YOUR-REPO-NAME/index.html</url>
    </source-location>
    <icon></icon>
    <permissions>
      <permission>full data</permission>
    </permissions>
    <encoding>
      <field id="group"  display-name="Groups" role="dimension" multi-value="false"/>
      <field id="spokes" display-name="Spokes" role="dimension" multi-value="true"/>
      <field id="values" display-name="Values" role="measure"   multi-value="false"/>
    </encoding>
  </worksheet-extension>
  <resources>
    <resource id="name">
      <text locale="en_US">Radar Chart</text>
    </resource>
  </resources>
</manifest>
